    result = JSON.parse(js);
  } catch (err1) {
    result = { gearCheck: [], warnings: [], missingRec: [] };
    try {
      var gcM = js.match(/"gearCheck"\s*:\s*(\[[\s\S]*?\])[\s,}]/);
      if (gcM) result.gearCheck = JSON.parse(gcM[1].replace(/,(\s*[}\]])/g, "$1"));
