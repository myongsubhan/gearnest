  if (c.includes("비")) return "🌧";
  if (c.includes("눈")) return "❄️";
  return "🌡";
}

var WX_CACHE = {};
var CACHE_MS = 5 * 60 * 1000;

async function fetchWeatherWithKey(loc, key) {
  var ctrl = new AbortController();
  var tid  = setTimeout(function() { ctrl.abort(); }, 9000);
  try {
    var qs = "&appid=" + key + "&units=metric&lang=kr";
    var base = "https://api.openweathermap.org/data/2.5/";
    var results = await Promise.all([
      fetch(base + "weather?lat=" + loc.lat + "&lon=" + loc.lon + qs, { signal: ctrl.signal }),
      fetch(base + "forecast?lat=" + loc.lat + "&lon=" + loc.lon + "&cnt=16" + qs, { signal: ctrl.signal }),
    ]);
    clearTimeout(tid);
    var cr = results[0]; var fr = results[1];
    if (!cr.ok) throw new Error("HTTP_" + cr.status);
    var parsed = await Promise.all([cr.json(), fr.ok ? fr.json() : null]);
    var cd = parsed[0]; var fd = parsed[1];
    var wid = cd.weather[0].id;
    var tzOff = cd.timezone;
    var nowLoc = new Date((Date.now() / 1000 + tzOff) * 1000);
    var timeStr = nowLoc.toISOString().slice(11, 16) + " (현지)";
    var tdMax = cd.main.temp_max; var tnMin = cd.main.temp_min;
    if (fd && fd.list) {
      var todayStr = new Date((fd.list[0].dt + tzOff) * 1000).toISOString().slice(0, 10);
      fd.list.forEach(function(item) {
        var dStr = new Date((item.dt + tzOff) * 1000).toISOString().slice(0, 10);
        if (dStr === todayStr) {
          if (item.main.temp_max > tdMax) tdMax = item.main.temp_max;
          if (item.main.temp_min < tnMin) tnMin = item.main.temp_min;
        }
      });
    }
    var rainP = (fd && fd.list && fd.list[0])
      ? Math.round((fd.list[0].pop || 0) * 100)
      : (wid >= 200 && wid < 700 ? 70 : Math.round(cd.clouds.all * 0.4));
    // 시간당 실제 강수량/적설량 (mm)
    var rainMm  = (cd.rain && cd.rain["1h"]) ? cd.rain["1h"] : 0;
    var snowMm  = (cd.snow && cd.snow["1h"]) ? cd.snow["1h"] : 0;
    // 풍향
    var windDeg = cd.wind.deg || 0;
    var windDirs = ["북","북동","동","남동","남","남서","서","북서"];
    var windDir = windDirs[Math.round(windDeg / 45) % 8];
    // 일출/일몰 (현지 시간)
    var sunrise = cd.sys.sunrise ? new Date((cd.sys.sunrise + tzOff) * 1000).toISOString().slice(11,16) : null;
    var sunset  = cd.sys.sunset  ? new Date((cd.sys.sunset  + tzOff) * 1000).toISOString().slice(11,16) : null;
    // 시간별 예보 (3시간 간격 8개 = 24시간)
    var hourly = [];
    if (fd && fd.list) {
      fd.list.slice(0, 16).forEach(function(item) {
        var dt = new Date((item.dt + tzOff) * 1000);
        var h = dt.toISOString().slice(11,16);
        hourly.push({
          time: h,
          temp: Math.round(item.main.temp),
          pop: Math.round((item.pop || 0) * 100),
          wind: Math.round(item.wind.speed * 10) / 10,
          cond: owmCond(item.weather[0].id),
          rainMm: (item.rain && item.rain["3h"]) ? (item.rain["3h"] / 3).toFixed(1) : "0",
        });
      });
    }
    return {
      ok: true, src: "OWM",
      label: loc.name + (loc.country ? ", " + loc.country : ""),
      lat: loc.lat, lon: loc.lon,
      temp: Math.round(cd.main.temp), feels: Math.round(cd.main.feels_like),
      hum: cd.main.humidity, wind: Math.round(cd.wind.speed * 10) / 10,
      windDir: windDir, windDeg: windDeg,
      rain: rainP, rainMm: rainMm, snowMm: snowMm, cond: owmCond(wid),
      tn: Math.round(tnMin), td: Math.round(tdMax), time: timeStr,
      sunrise: sunrise, sunset: sunset, hourly: hourly,
      dewPoint: Math.round(cd.main.temp - (100 - cd.main.humidity) / 5),
      pressure: cd.main.pressure,
      visibility: cd.visibility ? Math.round(cd.visibility / 100) / 10 : null,
    };
  } catch (e) {
    clearTimeout(tid);
    throw e;
  }
}

async function fetchWeather(loc) {
  if (!loc) return Object.assign({}, MOCK_WX);
  var cacheKey = loc.lat + "," + loc.lon;
  var hit = WX_CACHE[cacheKey];
  if (hit && Date.now() - hit.ts < CACHE_MS) return Object.assign({}, hit.data, { cached: true });
  var lastErr = null;
  for (var ki = 0; ki < OWM_KEYS.length; ki++) {
    try {
      var data = await fetchWeatherWithKey(loc, OWM_KEYS[ki]);
      WX_CACHE[cacheKey] = { data: JSON.parse(JSON.stringify(data)), ts: Date.now() };
      return data;
    } catch (e) { lastErr = e.message; continue; }
  }
  var stale = WX_CACHE[cacheKey];
  if (stale) return Object.assign({}, stale.data, { cached: true, src: "Cache" });
  return Object.assign({}, MOCK_WX, {
    label: loc.name + (loc.country ? ", " + loc.country : ""),
    src: "Mock",
  });
}

// 날씨 위험도 평가 — 각 요소별 멘트 배열 반환
function wxAlerts(w) {
  if (!w || !w.ok) return [];
  var alerts = [];
  // ① 강풍
  if (w.wind >= 20)      alerts.push({ lv:"danger",  icon:"🌪️", msg:"폭풍 " + w.wind + "m/s — 텐트 설치 위험, 캠핑 비권장" });
  else if (w.wind >= 14) alerts.push({ lv:"danger",  icon:"💨", msg:"강풍 " + w.wind + "m/s — 타프·텐트 팩 전체 고정 필수" });
  else if (w.wind >= 9)  alerts.push({ lv:"warn",    icon:"🌬️", msg:"바람 " + w.wind + "m/s — 팩·가이라인 고정 필수" });
  else if (w.wind >= 5)  alerts.push({ lv:"caution", icon:"🍃", msg:"바람 " + w.wind + "m/s — 팩 고정 권장" });
  // ② 강수 확률 + 실제 강수량
  var rmm = w.rainMm || 0;
  if (rmm >= 30)         alerts.push({ lv:"danger",  icon:"⛈️", msg:"시간당 " + rmm.toFixed(1) + "mm — 호우 경보, 야영 즉시 철수" });
  else if (rmm >= 10)    alerts.push({ lv:"danger",  icon:"🌧️", msg:"시간당 " + rmm.toFixed(1) + "mm — 집중호우, 방수 대책 긴급 필요" });
  else if (rmm >= 3)     alerts.push({ lv:"warn",    icon:"🌦️", msg:"시간당 " + rmm.toFixed(1) + "mm — 강우, 방수 타프 설치 필수" });
  else if (rmm >= 1)     alerts.push({ lv:"caution", icon:"🌂", msg:"시간당 " + rmm.toFixed(1) + "mm — 약한 비, 타프 권장" });
  else if (w.rain >= 70) alerts.push({ lv:"warn",    icon:"🌧️", msg:"강수 확률 " + w.rain + "% — 방수 장비 필수" });
  else if (w.rain >= 40) alerts.push({ lv:"caution", icon:"☂️", msg:"강수 확률 " + w.rain + "% — 우비·타프 준비" });
  // ③ 적설
  var smm = w.snowMm || 0;
  if (smm >= 10)         alerts.push({ lv:"danger",  icon:"❄️", msg:"시간당 " + smm.toFixed(1) + "cm 폭설 — 텐트 눈 하중 위험" });
  else if (smm >= 3)     alerts.push({ lv:"warn",    icon:"🌨️", msg:"시간당 " + smm.toFixed(1) + "cm 눈 — 텐트 폴 강도 확인" });
  else if (smm > 0)      alerts.push({ lv:"caution", icon:"⛄", msg:"적설 " + smm.toFixed(1) + "cm — 설상 대비 필요" });
  // ④ 저온
  if (w.tn < -15)        alerts.push({ lv:"danger",  icon:"🥶", msg:"야간 " + w.tn + "°C — 극동계 장비 필수, 저체온 위험" });
  else if (w.tn < -5)    alerts.push({ lv:"danger",  icon:"🌡️", msg:"야간 " + w.tn + "°C — 동계 침낭·방한 레이어 필수" });
  else if (w.tn < 0)     alerts.push({ lv:"warn",    icon:"🌡️", msg:"야간 " + w.tn + "°C — 동계 침낭 필수" });
  else if (w.tn < 5)     alerts.push({ lv:"caution", icon:"🌡️", msg:"야간 " + w.tn + "°C — 방한 레이어 권장" });
  // ⑤ 고온
  if (w.temp >= 35)      alerts.push({ lv:"danger",  icon:"🔥", msg:"낮 " + w.temp + "°C — 폭염 경보, 그늘막·수분 필수" });
  else if (w.temp >= 30) alerts.push({ lv:"warn",    icon:"☀️", msg:"낮 " + w.temp + "°C — 더위, 충분한 수분 보충" });
  else if (w.temp >= 26) alerts.push({ lv:"caution", icon:"🌤️", msg:"낮 " + w.temp + "°C — 자외선 차단제 필수" });
  // ⑥ 일교차
  var diff = w.td - w.tn;
  if (diff >= 20)        alerts.push({ lv:"warn",    icon:"🌡️", msg:"일교차 " + diff + "°C — 레이어링 시스템 필수" });
  else if (diff >= 15)   alerts.push({ lv:"caution", icon:"🧥", msg:"일교차 " + diff + "°C — 경량 다운 챙기기" });
  // 이상 없으면 쾌적
  if (alerts.length === 0) alerts.push({ lv:"good", icon:"✅", msg:w.cond + " " + w.temp + "°C — 쾌적한 캠핑 날씨" });
  return alerts;
}
