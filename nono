  } catch(e) { console.warn("[GearSearch] Edge 실패:", e.message); }

  // STEP 3: Gemini 내장
  console.log("[GearSearch] Gemini fallback 시작...");
  try {
    var geminiResult = await _searchViaGemini(brand);
    if (geminiResult && geminiResult.length > 0) {
      console.log("[GearSearch] Gemini 성공:", geminiResult.length + "개");
      // DB에 캐싱 (다음 검색 빠르게)
      geminiResult.forEach(function(item) {
        sbInsertGearDict({ name:item.name, brand:item.brand, weight_g:item.weight_g,
          cat:item.cat, wc:item.wc||"Base", specs:item.specs||"",
          opt_temp:item.opt_temp||null, limit_temp:item.limit_temp||null });
      });
      return geminiResult;
    }
  } catch(e) { console.warn("[GearSearch] Gemini 실패:", e.message); }

  return [];
}

// 로컬 AI 분석 폴백
function localGearAnalysis(locLabel, campStyle, wx, gear, targetWt) {
  targetWt = targetWt || 12;
  var w = wx && wx.ok ? wx : null;
  var tn = w?w.tn:8, wind = w?w.wind:3, rain = w?w.rain:10;
  // 부모 장비가 있는 옵션은 부모 추천 여부에 따라 함께 표시
  var parentRecommended = {};
  var gearCheck = gear.map(function(g) {
