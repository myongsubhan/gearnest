  if (t > 0)   return { l: "방한 필요",      c: "#B8860B", pct: Math.max(0, (25 - t) / 35 * 100) };
  if (t > -10) return { l: "동계 장비 필수", c: "#CC4400", pct: Math.max(0, (25 - t) / 35 * 100) };
  return              { l: "극한",            c: "#880000", pct: 100 };
}
function bplTier(kg) {
