// STEP 1: Edge Function 호출
async function _searchViaEdge(brand) {
  var res = await fetch(SUPA_URL + "/functions/v1/search-gear", {
    method: "POST",
    headers: { "Content-Type":"application/json", "apikey":SUPA_KEY, "Authorization":"Bearer "+SUPA_KEY },
    body: JSON.stringify({ keyword: brand, brand: brand }), // 양쪽 다 전송 (호환성)
    signal: (function(){ var c=new AbortController(); setTimeout(function(){c.abort();},15000); return c.signal; })(),
  });
  if (!res.ok) throw new Error("Edge " + res.status);
  var data = await res.json();
  // Edge Function 응답 형식 통일 처리
  // 기존: { items: [...] }  신규: { source, data: [{brand,name,weight,features,image}] }
  var rawItems = data.items || data.data || [];
  if (!rawItems || rawItems.length === 0) return null;
  // 신규 형식 변환 (weight, features → weight_g, specs)
  var normalized = rawItems.map(function(i) {
    if (i.weight_g !== undefined) return i; // 이미 기존 형식
    // 신규 형식: weight("370g") → weight_g(숫자), features → specs
    var wg = 0;
    if (i.weight) {
      var wMatch = String(i.weight).match(/(\d+(?:\.\d+)?)\s*(kg|g)/i);
      if (wMatch) wg = wMatch[2].toLowerCase() === "kg" ? Math.round(Number(wMatch[1]) * 1000) : Math.round(Number(wMatch[1]));
    }
    return {
      name: i.name || "",
      brand: i.brand || brand,
      weight_g: wg || 0,
      cat: i.cat || "ETC",
      wc: i.wc || "Base",
      specs: (function(){ var s = Array.isArray(i.features) ? i.features.join(", ") : (i.specs || ""); return s.replace(/₩[\d,]+/g, "").replace(/네이버 쇼핑 검색 결과\s*·?\s*/g, "").trim(); })(),
    };
  });
  var items = normalized.map(function(i) { return _mapGearItem(i, i.brand || brand, data.source === "database"); });
  // 검색어와 무관한 결과 필터링
  var qLower = brand.toLowerCase().replace(/[\s_-]/g, "");
  // 한글 검색어 → 영문 키워드 변환 (나이프→knife, 타프→tarp 등)
  var qEng = (function() {
    var map = {"나이프":"knife","칼":"knife","타프":"tarp","해먹":"hammock","텐트":"tent","침낭":"sleeping","배낭":"pack","스토브":"stove","버너":"stove","의자":"chair","랜턴":"lantern","매트":"pad","자켓":"jacket","장갑":"gloves"};
    return map[brand.trim()] || "";
  })();
  var filtered = items.filter(function(item) {
    var bLower = (item.brand || "").toLowerCase().replace(/[\s_-]/g, "");
    var nLower = (item.name  || "").toLowerCase().replace(/[\s_-]/g, "");
    var specL  = (item.specs || "").toLowerCase();
    var qLowerClean = qLower.replace(/[\s_-]/g,"");
    // 브랜드 검색이면 brand 필드 기준으로만 판단 (더 관대하게)
    var matchBrand = bLower.includes(qLowerClean) || qLowerClean.includes(bLower);
    var matchName  = nLower.includes(qLowerClean);
    var matchSpec  = specL.includes(brand.toLowerCase()) || specL.replace(/[\s_-]/g,"").includes(qLowerClean);
    var matchEng   = qEng ? (nLower.includes(qEng) || bLower.includes(qEng) || specL.includes(qEng)) : false;
    return matchBrand || matchName || matchSpec || matchEng;
  });
  // 디버그
  console.log("[EdgeFilter] q=" + brand + " qLower=" + qLower + " 결과:" + filtered.length + "/" + items.length);
  if (filtered.length === 0) return null;
  return filtered;
}

