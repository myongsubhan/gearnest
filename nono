  var hasCutlery = cookGear.some(function(g){ var m=(g.memo||g.n).toLowerCase(); return m.indexOf("수저")>-1||m.indexOf("젓가락")>-1||m.indexOf("스포크")>-1||m.indexOf("spork")>-1||m.indexOf("chopstick")>-1||m.indexOf("spoon")>-1||m.indexOf("curved")>-1||m.indexOf("fork")>-1||m.indexOf("집게")>-1||m.indexOf("tong")>-1||m.indexOf("cutlery")>-1; });
  var hasCup     = cookGear.some(function(g){ var m=(g.memo||g.n).toLowerCase(); return m.indexOf("컵")>-1||m.indexOf("머그")>-1||m.indexOf("cup")>-1||m.indexOf("mug")>-1||m.indexOf("코펠")>-1||m.indexOf("cookset")>-1||m.indexOf("duossal")>-1||m.indexOf("pot")>-1||m.indexOf("접시")>-1||m.indexOf("bowl")>-1||m.indexOf("pan")>-1||m.indexOf("kettle")>-1||m.indexOf("케틀")>-1; });
