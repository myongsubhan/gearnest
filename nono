      "Zpacks":      { season4: false, windOk: false, snowOk: false, note: "3시즌 DCF 초경량 전문" },
      "HMG":         { season4: false, windOk: false, snowOk: false, note: "3시즌 DCF 백패킹" },
      "Durston Gear":{ season4: false, windOk: false, snowOk: false, note: "3시즌 DCF 백패킹" },
      "Naturehike":  { season4: false, windOk: false, snowOk: false, note: "3시즌 입문용" },
      // 오토캠핑 전문
      "Snow Peak":   { season4: false, windOk: false, snowOk: false, note: "오토캠핑/글램핑 전문" },
      "Coleman":     { season4: false, windOk: false, snowOk: false, note: "오토캠핑 입문용" },
      "DOD":         { season4: false, windOk: false, snowOk: false, note: "오토캠핑/패밀리 전문" },
      "Helinox":     { season4: false, windOk: false, snowOk: false, note: "경량 알루미늄 퍼니처 전문" },
      // 초경량 한국 브랜드
      "Zerogram":    { season4: false, windOk: false, snowOk: false, note: "한국 울트라라이트 DCF 전문" },
      "Minimal Works":{ season4: false, windOk: false, snowOk: false, note: "한국 캠핑 전문" },
    };
    var bt = BRAND_TRAITS[g.br] || {};

    // ── 계절 판단 (야간 최저기온 기준) ──────────────────────
    var season = tn >= 10 ? "summer" : tn >= 0 ? "spring" : tn >= -10 ? "winter" : "extreme";
    var seasonLabel = { summer:"하계", spring:"춘추계", winter:"동계", extreme:"극동계" }[season];

    // ── 캠핑 스타일 × 계절별 무게 기준 ──────────────────────
    var wLimit = null;
    if (campStyle === "Backpacking") {
      // 현실적인 백패킹 카테고리 무게 기준 (10~15kg 총합 기준)
      var bpBase = {
        summer:  { Tent:1800, Shelter:1500, Sleep:800,  Bag:1600, Chair:1000, Cookware:300, Cooking:500,  Clothing:600,  Cot:3000, Safety:200, Table:800,  ETC:500 },
        spring:  { Tent:1800, Shelter:1800, Sleep:1200, Bag:1800, Chair:1000, Cookware:350, Cooking:600,  Clothing:800,  Cot:3000, Safety:250, Table:1000, ETC:600 },
        winter:  { Tent:3500, Shelter:2500, Sleep:2000, Bag:2000, Chair:1000,  Cookware:400, Cooking:700,  Clothing:1200, Cot:3000, Safety:300, Table:1200, ETC:700 },
