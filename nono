      "Helsport":    { season4: true,  windOk: true,  snowOk: true,  note: "노르딕 4시즌 터널텐트" },
      "Samaya":      { season4: true,  windOk: true,  snowOk: true,  note: "알파인 원정 전문, 극한 내구성" },
      "MSR":         { season4: true,  windOk: true,  snowOk: true,  note: "4시즌 포함 다목적 텐트 라인 보유" },
      // 3시즌 + 준4시즌
