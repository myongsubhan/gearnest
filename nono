    return { n:g.n, ok:score>=60, score:score, reason:reasons.length?reasons[0]:"현재 날씨 조건에 적합", season:season };
  });

  // 카테고리별 최고점 1개만 (이름 기준 비교 — 객체참조 버그 방지)
