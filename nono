function searchLocalDB(query) {
  if (!query || query.length < 1) return [];
  var q = query.trim().toLowerCase();
  var qNoSpace = q.replace(/\s+/g, "");
  var abbrev = {
    "강원": "강원도", "경기": "경기도", "충북": "충청북도",
    "충남": "충청남도", "전북": "전라북도", "전남": "전라남도",
    "경북": "경상북도", "경남": "경상남도", "제주": "제주도",
  };
  var expanded = abbrev[qNoSpace] || null;
  var results = LOC_DB.filter(function(loc) {
    var hay = (loc.name + " " + loc.nameEn + " " + loc.region + " " + loc.tags).toLowerCase().replace(/\s+/g, "");
    if (expanded && hay.includes(expanded.toLowerCase())) return true;
    return hay.includes(qNoSpace);
  });
  results.sort(function(a, b) {
    var aName = a.name.toLowerCase();
    var bName = b.name.toLowerCase();
    var aStart = aName.startsWith(q) ? 0 : aName.includes(q) ? 1 : 2;
    var bStart = bName.startsWith(q) ? 0 : bName.includes(q) ? 1 : 2;
    return aStart - bStart;
  });
  // 같은 이름 또는 같은 좌표(소수점 2자리) 중복 제거
  var seenKey = {};
  results = results.filter(function(r) {
    var key = r.name + "|" + r.lat.toFixed(2) + "," + r.lon.toFixed(2);
    if (seenKey[key]) return false;
    seenKey[key] = true;
    return true;
  });
  return results.slice(0, 8);
}

