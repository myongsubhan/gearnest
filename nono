    try {
      var wnM = js.match(/"warnings"\s*:\s*(\[[\s\S]*?\])[\s,}]/);
      if (wnM) result.warnings = JSON.parse(wnM[1].replace(/,(\s*[}\]])/g, "$1"));
    } catch (e) {}
    try {
      var mrM = js.match(/"missingRec"\s*:\s*(\[[\s\S]*?\])[\s,}]/);
      if (mrM) result.missingRec = JSON.parse(mrM[1].replace(/,(\s*[}\]])/g, "$1"));
    } catch (e) {}
    if (!result.gearCheck.length && !result.missingRec.length) {
