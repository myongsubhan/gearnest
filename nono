  if (kg < 9)  return { code: "UL", label: "Ultralight",   color: "#1A7A4A", tip: "UL (~9kg) — 울트라라이트. 3계절 이상적 목표치." };
  if (kg < 15) return { code: "LW", label: "Lightweight",  color: "#3388CC", tip: "LW (9~15kg) — 경량 구성." };
  if (kg < 20) return { code: "TR", label: "Traditional",  color: "#B8860B", tip: "TR (15~20kg) — 전통적인 백패킹 무게." };
  if (kg < 30) return { code: "HV", label: "Heavy",        color: "#CC4400", tip: "HV (20~30kg) — 짧은 거리 적합." };
  return         { code: "MX", label: "Maximal",       color: "#991B1B", tip: "MX (30kg+) — 차량 지원 권장." };
}
function buildChecklist(wx, wr, rr, sleepGear) {
  var items = [];
  if (!wx || !wx.ok) return items;
  var diff = wx.td - wx.tn;
  var matched = false;
  (sleepGear || []).forEach(function(g) {
    if (g.cat !== "Sleep" || g.optTemp === undefined) return;
    matched = true;
    var lim = g.limitTemp !== undefined ? g.limitTemp : g.optTemp - 3;
    if (wx.tn < lim) items.push("⚠️ " + g.n + " 한계온도 초과 위험!");
    else if (wx.tn < g.optTemp) items.push("🌡 " + g.n + " 최적온도 이하 — 레이어 추가");
    else items.push("✅ " + g.n + " 야간온도 적합");
  });
  if (!matched) {
    if (wx.tn < 0) items.push("🧊 동계 침낭 필수 (야간 " + wx.tn + "°C)");
    else if (wx.tn < 5) items.push("🧥 -5°C급 침낭 권장");
    else if (wx.tn < 12) items.push("🌡 3계절 침낭 권장");
    else items.push("😊 경량 침낭 가능");
  }
  if (diff >= 15) items.push("↕ 일교차 " + diff + "°C — 경량 다운 필수");
  else if (diff >= 10) items.push("↕ 일교차 " + diff + "°C — 경량 다운 챙기기");
  if (rr.pct >= 60) { items.push("☔ 방수 타프 필수"); items.push("💧 드라이색 필수"); }
  else if (rr.pct >= 40) { items.push("☔ 방수 타프 권장"); items.push("🌂 우비 필수"); }
  else if (rr.pct >= 20) items.push("🌂 우비 준비");
  else items.push("✅ 강수 걱정 없음");
  if (wr.pct >= 75) { items.push("⚓ 강풍! 팩 전부 고정"); items.push("🔩 풀팩 필수"); }
  else if (wr.pct >= 50) items.push("⚓ 팩 고정 + 가이라인");
  else items.push("✅ 바람 안전");
  return items;
}
