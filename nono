  if (!Array.isArray(result.warnings)) result.warnings = [];
  if (!Array.isArray(result.missingRec)) result.missingRec = [];
  result.gearCheck.sort(function(a, b) { return (b.score || 50) - (a.score || 50); });
  result.missingRec.sort(function(a, b) { return (b.score || 50) - (a.score || 50); });
  return result;
}

