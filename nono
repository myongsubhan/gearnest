async function geocode(query) {
  if (!query || query.length < 1) return [];
  var localResults = searchLocalDB(query);
  var owmResults = [];
  for (var ki = 0; ki < OWM_KEYS.length; ki++) {
    try {
      var url = "https://api.openweathermap.org/geo/1.0/direct?q=" +
        encodeURIComponent(query) + "&limit=5&appid=" + OWM_KEYS[ki];
      var res = await fetch(url);
      if (!res.ok) continue;
      var list = await res.json();
      if (list && list.length > 0) {
        owmResults = list.map(function(item) {
          return {
            name: item.local_names && item.local_names.ko ? item.local_names.ko : item.name,
            nameEn: item.name, country: item.country,
            state: item.state || "", region: item.state || "",
            lat: item.lat, lon: item.lon, tags: "",
          };
        });
        break;
      }
    } catch (ge) { continue; }
  }
  var combined = localResults.slice();
  owmResults.forEach(function(owm) {
    var isDup = combined.some(function(loc) {
      return Math.abs(loc.lat - owm.lat) < 0.15 && Math.abs(loc.lon - owm.lon) < 0.15;
    });
    if (!isDup) {
      // OWM state 없거나 영문이면 LOC_DB에서 한국어 행정구역 보강
      var needState = !owm.state || owm.state === owm.country || /^[A-Z]/.test(owm.state||"");
      if (needState) {
        // 반경 점점 넓혀서 찾기
        var radiuses = [0.2, 0.5, 1.0, 2.0];
        for (var ri = 0; ri < radiuses.length; ri++) {
          var r = radiuses[ri];
          var nearby = LOC_DB.find(function(loc) {
            return loc.state && Math.abs(loc.lat - owm.lat) < r && Math.abs(loc.lon - owm.lon) < r;
          });
          if (nearby && nearby.state) { owm.state = nearby.state; break; }
        }
      }
      combined.push(owm);
    }
  });
  // OWM 결과 중복 제거 (같은 이름 + 좌표)
  var seenComb = {};
  combined = combined.filter(function(r) {
    var key = (r.name||r.nameEn||"") + "|" + (r.lat||0).toFixed(1);
    if (seenComb[key]) return false;
    seenComb[key] = true;
    return true;
  });
  return combined.slice(0, 8);
}

function owmCond(id) {
  if (id >= 200 && id < 300) return "뇌우";
  if (id >= 300 && id < 400) return "이슬비";
  if (id >= 500 && id < 600) { if (id === 500) return "가벼운 비"; if (id >= 502) return "폭우"; return "비"; }
  if (id >= 600 && id < 700) return "눈";
  if (id === 800) return "맑음";
  if (id === 801) return "구름 조금";
  if (id === 802) return "구름 약간";
  if (id >= 803) return "흐림";
  if (id >= 700) return "안개";
  return "알 수 없음";
}
function wEmoji(c) {
  if (!c) return "🌡";
  if (c.includes("맑")) return "☀️";
  if (c.includes("구름")) return "⛅";
  if (c.includes("흐")) return "☁️";
  if (c.includes("안개")) return "🌫";
