      };
      wLimit = (brBase[season][g.cat]) || 1500;
    }

    // 무게 초과 체크 — wc=Wear 의류는 제외, 나머지는 비율 기반 감점
    if (wLimit && g.wg > wLimit && g.wc !== "Wear") {
      var overRatio = g.wg / wLimit;
      if (overRatio > 3) {
        score = 20;  // 3배 초과 = 확실한 부적합
        reasons.push(g.wg + "g — " + campStyle + " 무게 기준 대폭 초과 (" + wLimit + "g 권장)");
