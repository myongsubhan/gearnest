    // 모토/오토캠핑도 쿠킹 세분화
    if(!hasBurner)  missingRec.push({cat:"Cooking", prod:"버너",           brand:"Snow Peak / Kovea", wg:300, score:80,reason:"버너가 없습니다.",price:""});
    if(!hasFuel)    missingRec.push({cat:"Cooking", prod:"가스 캐니스터",   brand:"Snow Peak / MSR",   wg:400, score:78,reason:"연료(가스)가 없습니다.",price:""});
    if(!hasCutlery) missingRec.push({cat:"Cooking",prod:"수저세트",        brand:"추천",              wg:50,  score:72,reason:"수저/젓가락/집게가 없습니다.",price:""});
    if(!hasCup)     missingRec.push({cat:"Cooking",prod:"컵+접시 세트",    brand:"추천",              wg:200, score:70,reason:"식기(컵/접시)가 없습니다.",price:""});
    if(!hasKnife)   missingRec.push({cat:"Cooking",prod:"캠핑 나이프",     brand:"Victorinox / Opinel",wg:80,score:38,reason:"나이프는 선택 장비입니다.",price:"",optional:true});
  }
  var warnings=[];
  if(tn<0) warnings.push("야간 "+tn+"°C — 동계 장비 필수");
  if(wind>=10) warnings.push("강풍 "+wind+"m/s — 팩 전체 고정 필수");
  if(rain>=60) warnings.push("강수 "+rain+"% — 방수 타프 필수");
  gearCheck.sort(function(a,b){return (b.score||50)-(a.score||50);});
  return { gearCheck:gearCheck, warnings:warnings, missingRec:missingRec, isLocal:true };
}

async function callLLM(body) {
  var ctrl = new AbortController();
  var tid = setTimeout(function() { ctrl.abort(); }, 30000);
  var userMsg = "";
  if (body.messages && body.messages.length > 0) {
    userMsg = body.messages.map(function(m) { return m.content; }).join("\n");
  }
  if (body.system) userMsg = body.system + "\n\n" + userMsg;
  var geminiBody = {
    contents: [{ parts: [{ text: userMsg }] }],
    generationConfig: { maxOutputTokens: body.max_tokens || 1000, temperature: 0.3 },
  };
  try {
    var models = ["gemini-2.5-flash-lite", "gemini-2.5-flash"];
    var res = null;
    for (var mi = 0; mi < models.length; mi++) {
      var url = "https://generativelanguage.googleapis.com/v1beta/models/" + models[mi] + ":generateContent";
      try {
        res = await fetch(url, { method: "POST", headers: { "Content-Type": "application/json", "x-goog-api-key": _getGeminiKey() }, body: JSON.stringify(geminiBody), signal: ctrl.signal });
        if (res.status === 429 && mi < models.length-1) { _rotateGeminiKey(); res = null; await new Promise(function(r){setTimeout(r, 3000 + mi * 1000);}); continue; }
        if (res.status === 404 && mi < models.length-1) { res = null; continue; }
        break;
      } catch(fe) { if (mi < models.length-1) continue; throw fe; }
    }
    clearTimeout(tid);
    if (!res || !res.ok) {
      var et = res ? await res.text().catch(function(){return "";}) : "";
      throw new Error("Gemini " + (res?res.status:0) + ": " + et.slice(0,80));
    }
    var data = await res.json();
    var text = "";
    try { text = data.candidates[0].content.parts[0].text; } catch(e) { text = ""; }
    return { content: [{ type: "text", text: text }] };
  } catch(e) {
    clearTimeout(tid);
    if (e.name === "AbortError") throw new Error("시간 초과");
    throw e;
  }
}

