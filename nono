function koToBrand(q) {
  var lower = q.trim().toLowerCase().replace(/[\s_-]/g,"");
  if (!lower || lower.length < 2) return null;
  // 1) 완전 매칭
  if (KO_BRAND_MAP[lower]) return KO_BRAND_MAP[lower];
  // 2) 앞부분 매칭 (입력 2자 이상)
  var keys = Object.keys(KO_BRAND_MAP);
  for (var i = 0; i < keys.length; i++) {
    var k = keys[i].replace(/[\s_-]/g,"");
    if (k.startsWith(lower) || (lower.length >= 2 && k.startsWith(lower.slice(0,2)) && lower.length >= k.length/2)) {
      return KO_BRAND_MAP[keys[i]];
    }
  }
  // 3) 포함 매칭 — 검색어와 브랜드키가 충분히 유사할 때만 (나이프→나이키 오매칭 방지)
  if (lower.length >= 3) {
    for (var j = 0; j < keys.length; j++) {
      var kj = keys[j].replace(/[\s_-]/g,"");
      // 검색어가 브랜드키와 70% 이상 길이가 같을 때만 포함 매칭 허용
      var minLen = Math.min(lower.length, kj.length);
      var maxLen = Math.max(lower.length, kj.length);
      if (minLen / maxLen >= 0.7 && (kj.includes(lower) || lower.includes(kj))) {
        return KO_BRAND_MAP[keys[j]];
      }
    }
  }
  // 4) 영문→한글 변환 역방향: 입력이 한글이면 영문 단어들과 매칭
  if (/[가-힣]/.test(q) && lower.length >= 2) {
    var allItems = (typeof gearSearchRes !== "undefined" ? gearSearchRes : [])
      .concat(typeof gearBrowseRes !== "undefined" ? gearBrowseRes : []);
    // 이미 로드된 장비 중 한글 발음이 일치하는 것 찾기
    for (var ai = 0; ai < allItems.length; ai++) {
      if (koMatchesName(lower, allItems[ai].name)) {
        return allItems[ai].brand;  // 브랜드 반환
      }
    }
  }
  return null;
}

