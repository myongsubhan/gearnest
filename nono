    if(!hasBurner)  missingRec.push({cat:"Cooking", prod:"경량 버너",      brand:"MSR / Snow Peak",  wg:73,  score:82,reason:"버너가 없습니다. PocketRocket 2(73g) 등 경량 캐니스터 버너를 추천합니다.",price:""});
    if(!hasFuel)    missingRec.push({cat:"Cooking", prod:"가스 캐니스터",   brand:"MSR / Snow Peak",  wg:200, score:80,reason:"연료(가스)가 없습니다. 110g 캐니스터 1개면 1박 2일 충분합니다.",price:""});
    if(!hasCutlery) missingRec.push({cat:"Cooking",prod:"수저 또는 스포크",brand:"Snow Peak / TOAKS",wg:20,  score:75,reason:"수저/젓가락이 없습니다. 티타늄 스포크(19g) 또는 수저+젓가락 세트를 추천합니다.",price:""});
    if(!hasCup)     missingRec.push({cat:"Cooking",prod:"컵 또는 코펠",    brand:"Snow Peak / MSR",  wg:100, score:73,reason:"식기(컵/코펠)가 없습니다. 티타늄 머그 또는 경량 코펠을 추천합니다.",price:""});
    if(!hasKnife)   missingRec.push({cat:"Cooking",prod:"캠핑 나이프",     brand:"Victorinox / Opinel",wg:60,score:40,reason:"나이프는 선택 장비입니다. 간편한 스위스 아미 나이프를 추천합니다.",price:"",optional:true});
  } else {
    if(!hasCat["Tent"]&&!hasCat["Shelter"]) missingRec.push({cat:"Tent",prod:"텐트",brand:"추천",wg:2000,score:85,reason:"텐트/쉘터가 없습니다",price:""});
