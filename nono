function engToKo(text) {
  if (!text) return "";
  var words = text.toLowerCase().replace(/[^a-z0-9\s]/g," ").split(/\s+/);
  var result = [];
  for (var i = 0; i < words.length; i++) {
    var w = words[i];
    if (!w) continue;
    var ko = EN_TO_KO[w];
    if (!ko) {
      // 단어 끝 숫자/알파 분리 (예: "xlite2" → "엑스라이트 2")
      var base = w.replace(/[0-9a-z]*$/, function(m) { return m.replace(/[^0-9]/g,""); });
      var cleaned = w.replace(/[0-9]+$/,"");
      var num = w.slice(cleaned.length);
      ko = EN_TO_KO[cleaned] || null;
      if (!ko) ko = w;  // 변환 못하면 원문 유지
      if (num) ko = ko + " " + num;
    }
    // 순수 숫자면 그냥 유지
    if (/^[0-9]+$/.test(w)) ko = w;
    result.push(ko);
  }
  return result.join(" ");
}

