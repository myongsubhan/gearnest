    "Respond with JSON only. Be strict on style criteria:",
  ].join("\n");
  var d = await callLLM({
    model: "claude-3-5-sonnet-20241022", max_tokens: 2000,
    messages: [{ role: "user", content: prompt }],
  });
  var txt = (d.content && d.content[0] && d.content[0].text) ? d.content[0].text : "";
  var tb = String.fromCharCode(96, 96, 96);
  txt = txt.split(tb + "json").join("").split(tb).join("");
  txt = txt.replace(/[\u201C\u201D]/g, '"').replace(/[\u2018\u2019]/g, "'");
  var si = txt.indexOf("{"); var ei = txt.lastIndexOf("}");
